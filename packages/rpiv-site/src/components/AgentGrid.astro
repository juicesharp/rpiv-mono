---
import { getAgentsByTier, type CapabilityTier, siteDescription } from "../lib/agents";

const groups = await getAgentsByTier();

const TIER_META: Record<CapabilityTier, { label: string; note: string; cap: string }> = {
	locator:    { label: "Locators",                note: "where. No file content access.",                                       cap: "find" },
	analyzer:   { label: "Analyzers",               note: "how. Reads file content, plus git history via precedent-locator.",     cap: "read" },
	external:   { label: "External agents",         note: "+ web search and fetch",                                               cap: "web"  },
	specialist: { label: "Code-review specialists", note: "Pipe-delimited findings, never prose.",                                cap: "rows" },
};
---

<section id="agents">
	<div class="container">
		<h2>Specialists, not generalists.</h2>
		<p class="agents__lede">
			Skills do orchestration. Agents do one narrow thing. Each is isolated,
			each is read-only, each tier is defined by its tool allowlist.
		</p>

		<div class="agents__list">
			{groups.map(({ tier, agents }, tierIdx) => agents.length > 0 && (
				<article class="tier__block">
					<header class="tier__header">
						<h3>Tier {tierIdx + 1}: {TIER_META[tier].label}</h3>
						<p>{TIER_META[tier].note} (Capability: <code>{TIER_META[tier].cap}</code>)</p>
					</header>

					<ul class="agent__ul">
						{agents.map((agent) => {
							const desc = siteDescription(agent);
							const dispatched = agent.copy?.dispatched_by?.length ?? 0;
							const tools = agent.data.tools?.split(",").map((t) => t.trim()).filter(Boolean) ?? [];

							return (
								<li class="agent__li">
									<strong>{agent.slug}</strong> 
									{dispatched > 0 && (
										<span class="agent__multiplier">
											(Used by {dispatched} skill{dispatched === 1 ? "" : "s"})
										</span>
									)}
									<p>{desc}</p>
									{tools.length > 0 && (
										<div class="agent__tools">
											<strong>Tools:</strong>
											<ul class="mono">
												{tools.map(t => <li>{t}</li>)}
											</ul>
										</div>
									)}
								</li>
							);
						})}
					</ul>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.agents__lede {
		margin-bottom: var(--space-6);
		color: var(--text-quiet);
	}

	.tier__block {
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-6);
		border-bottom: 1px solid var(--rule);
	}

	.tier__header {
		margin-bottom: var(--space-4);
	}

	.tier__header h3 {
		color: var(--sage);
		margin-bottom: var(--space-1);
	}

	.agent__ul {
		list-style: square;
		padding-left: var(--space-5);
	}

	.agent__li {
		margin-bottom: var(--space-6);
	}
	
	.agent__li strong {
		color: var(--washi);
	}

	.agent__li > span {
		color: var(--text-distant);
		font-size: var(--type-small);
	}

	.agent__multiplier {
		color: var(--text-distant);
		margin-left: var(--space-2);
	}

	.agent__tools {
		margin-top: var(--space-2);
		font-size: var(--type-small);
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-2);
	}

	.agent__tools strong {
		color: var(--text-quiet);
	}

	.agent__tools ul {
		margin: 0;
		padding: 0;
		color: var(--sage);
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
	}
</style>
