---
import { loadSiblings } from "../lib/siblings";

const siblings = loadSiblings();
---

<section id="siblings">
	<div class="container">
		<h2>Tools, not infrastructure.</h2>
		<p class="siblings__lede">
			rpiv-pi registers zero tools. Every tool surface lives in a sibling extension,
			detected by a regex over <code>~/.pi/agent/settings.json</code>.
			<code>/rpiv-setup</code> installs the missing ones in a single confirm.
		</p>

		<ul class="siblings__list">
			{siblings.map((s, i) => (
				<li class="sibling__item">
					<h3>
						{s.name} <span class="mono badge">v{s.version}</span>
					</h3>
					<div class="sibling__meta">
						<strong>Role:</strong> {s.role} &nbsp;|&nbsp; 
						<strong>Peers:</strong> {s.peers.length > 0 ? s.peers.join(", ") : "none"}
					</div>
					<p>{s.description}</p>
					
					<div class="sibling__install mono">
						<code>$ {s.installCmd}</code>
					</div>
					
					<div class="sibling__links mono">
						<a href={s.npmUrl}>[npm]</a>
						<a href={s.homepage}>[readme]</a>
					</div>
				</li>
			))}
		</ul>
	</div>
</section>

<style>
	.siblings__lede {
		margin-bottom: var(--space-6);
		color: var(--text-quiet);
	}

	.siblings__list {
		list-style: none;
		padding: 0;
		margin: var(--space-6) 0;
	}

	.sibling__item {
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-6);
		border-bottom: 1px solid var(--rule);
	}

	.sibling__item h3 {
		margin-bottom: var(--space-2);
		color: var(--sage);
		display: flex;
		align-items: baseline;
		gap: var(--space-3);
	}

	.badge {
		font-size: var(--type-small);
		color: var(--text-distant);
		font-weight: normal;
	}

	.sibling__meta {
		font-size: var(--type-small);
		margin-bottom: var(--space-4);
		color: var(--text-quiet);
	}
	
	.sibling__meta strong {
		color: var(--washi);
	}

	.sibling__install {
		margin: var(--space-4) 0;
		padding: var(--space-3) var(--space-4);
		background: var(--ink-raised);
		border-left: 4px solid var(--rule-strong);
		font-size: var(--type-small);
	}

	.sibling__links {
		display: flex;
		gap: var(--space-4);
		margin-top: var(--space-4);
	}
	
	.sibling__links a {
		text-decoration: none;
		color: var(--sage);
	}
	
	.sibling__links a:hover {
		color: var(--washi);
		text-decoration: underline;
	}
</style>
