---
// §5 — the skills that surround a flow. Standalone skills grouped by their
// moment relative to a run. A spare "where they fit" schematic answers the
// spatial question; the grouped cards carry the detail.
import { getAroundSkills, type AroundSkill } from "../lib/around-skills";

const skills = await getAroundSkills();
const GROUPS = [
	{ key: "before", label: "Before the run", hint: "frame the work before a flow starts" },
	{ key: "context", label: "Standing context", hint: "per-folder docs the agent reads as it works" },
	{ key: "across", label: "Across sessions", hint: "save a run's state, pick it up later" },
	{ key: "edges", label: "Around the edges", hint: "direction going in, release coming out" },
] as const;
const byMoment = (m: string): AroundSkill[] => skills.filter((s) => s.moment === m);
---

<section id="around">
	<div class="container">
		<p class="kicker">§ around the flow · before, beside, after</p>
		<h2>The skills you reach for around a run.</h2>
		<p class="ar__lede">
			These aren&rsquo;t stages of any flow. They frame the work before it
			starts, hold context underneath it, bridge it across sessions, and record
			it when it lands.
		</p>

		<figure class="ar-fig" aria-label="Where the standalone skills fit relative to a run: discover and explore feed in before; annotate-guidance holds standing context the agent reads on every tool call; create-handoff and resume-handoff bridge a paused run across sessions; changelog records it after.">
			<svg viewBox="0 0 860 200" class="ar-svg" preserveAspectRatio="xMidYMid meet" role="presentation">
				{/* the run */}
				<text x="465" y="60" text-anchor="middle" font-family="var(--font-mono)" font-size="11" fill="var(--text-distant)" letter-spacing="0.06em">a /wf run</text>
				<g fill="none" stroke="var(--sage-deep)" stroke-linecap="round">
					<path d="M352,84 L578,84" stroke-width="1" opacity="0.7" />
					<path d="M360,88 L570,88" stroke-width="0.5" opacity="0.22" />
				</g>
				{[366, 437, 508, 564].map((x) => (
					<g>
						<circle cx={x} cy="84" r="7" fill="none" stroke="var(--sage)" stroke-width="0.6" opacity="0.4" />
						<circle cx={x} cy="84" r="4.5" fill="var(--ink)" stroke="var(--sage)" stroke-width="1" />
						<circle cx={x} cy="84" r="4.5" fill="var(--sage)" opacity="0.16" />
					</g>
				))}

				{/* before — feeds into the head */}
				<text x="44" y="74" font-family="var(--font-mono)" font-size="11" fill="var(--text-distant)" letter-spacing="0.14em">BEFORE</text>
				<text x="44" y="94" font-family="var(--font-mono)" font-size="11" fill="var(--sage)" letter-spacing="0.02em">discover · explore</text>
				<g fill="none" stroke="var(--ochre)" stroke-linecap="round" opacity="0.7">
					<path d="M210,98 Q280,90 344,86" stroke-width="1.1" stroke-dasharray="4 3" />
					<path d="M338,82 L345,86 L338,90" stroke-width="1" />
				</g>

				{/* after — flows out of the tail */}
				<text x="694" y="74" font-family="var(--font-mono)" font-size="11" fill="var(--text-distant)" letter-spacing="0.14em">AFTER</text>
				<text x="694" y="94" font-family="var(--font-mono)" font-size="11" fill="var(--sage)" letter-spacing="0.02em">changelog</text>
				<g fill="none" stroke="var(--ochre)" stroke-linecap="round" opacity="0.7">
					<path d="M586,86 Q650,90 686,86" stroke-width="1.1" stroke-dasharray="4 3" />
					<path d="M680,82 L687,86 L680,90" stroke-width="1" />
				</g>

				{/* standing context — band beneath the whole run */}
				<g fill="none" stroke="var(--sage)" stroke-linecap="round" opacity="0.5">
					<path d="M352,104 L352,110 L578,110 L578,104" stroke-width="0.8" />
				</g>
				<text x="465" y="126" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--text-distant)" letter-spacing="0.04em">standing context · read on every tool call</text>

				{/* across sessions — bridge */}
				<path d="M398,156 Q465,142 532,156" fill="none" stroke="var(--ochre)" stroke-width="0.9" opacity="0.55" stroke-dasharray="3 3" />
				<text x="465" y="170" text-anchor="middle" font-family="var(--font-mono)" font-size="11" fill="var(--text-quiet)" letter-spacing="0.02em">create-handoff ⇢ resume-handoff</text>
				<text x="465" y="188" text-anchor="middle" font-family="var(--font-mono)" font-size="9.5" fill="var(--text-distant)" letter-spacing="0.06em">across sessions</text>
			</svg>
		</figure>

		{GROUPS.map((group) => (
			<div class="ar__group">
				<header class="ar__groupHead">
					<h3 class="mono ar__groupName">{group.label}</h3>
					<span class="ar__groupHint">{group.hint}</span>
				</header>
				<div class="ar__cards" role="list">
					{byMoment(group.key).map((s) => (
						<article class="ar-card" role="listitem">
							<header class="ar-card__head">
								<span class="chip chip--sage">/skill:{s.name}</span>
								<span class="ar-card__out mono">{s.output}</span>
							</header>
							<p class="ar-card__role">{s.role}</p>
						</article>
					))}
				</div>
			</div>
		))}
	</div>
</section>

<style>
	.ar__lede {
		font-family: var(--font-serif);
		max-width: 58ch;
		color: var(--text-quiet);
		font-size: var(--type-lead);
		line-height: var(--leading-body);
		margin: var(--space-4) 0 var(--space-7);
		text-wrap: pretty;
	}

	.ar-fig { margin: 0 0 var(--space-8); }
	.ar-svg { width: 100%; max-width: 820px; height: auto; display: block; overflow: visible; }

	.ar__group { margin-bottom: var(--space-6); }
	.ar__groupHead {
		display: flex;
		align-items: baseline;
		gap: var(--space-3);
		margin-bottom: var(--space-4);
		padding-bottom: var(--space-2);
		border-bottom: 1px solid var(--rule-strong);
	}
	.ar__groupName { font-size: var(--type-h3); color: var(--text); margin: 0; }
	.ar__groupHint {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: var(--type-small);
		color: var(--text-distant);
	}

	.ar__cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: var(--space-4);
	}

	.ar-card {
		/* Canonical two-tone card edge — recessed top/sides (--rule), weighted
		   base (--rule-strong) — matching the global .card hairline signature. */
		border-top: 1px solid var(--rule);
		border-left: 1px solid var(--rule);
		border-right: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule-strong);
		border-radius: var(--radius-sm);
		padding: var(--space-4) var(--space-5);
		background: var(--ink-raised);
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.ar-card__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-2);
	}
	.ar-card__out {
		font-size: var(--type-micro);
		color: var(--text-distant);
		letter-spacing: 0.02em;
		text-align: right;
	}
	.ar-card__role {
		font-family: var(--font-serif);
		font-size: var(--type-base);
		line-height: var(--leading-snug);
		color: var(--text-quiet);
		margin: 0;
		text-wrap: pretty;
	}

	@media (max-width: 720px) {
		.ar__cards { grid-template-columns: 1fr; }
	}
</style>
