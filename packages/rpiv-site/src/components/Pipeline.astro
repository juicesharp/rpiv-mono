---
import { ARTIFACT_WRITE_SITES, PIPELINE_META, type PipelineStep, getPipelineSkills, getSkill } from "../lib/skills";
const pipeline = await getPipelineSkills();
const revise = await getSkill("revise");
---

<section id="pipeline">
	<div class="container">
		<p class="kicker">§ default pipeline · 6 nodes</p>
		<h2>A six-step chain. One artifact between each.</h2>
		<p class="pipeline__lede">
			Each node is a skill. The artifact one writes is the next one&rsquo;s input.
		</p>

		<figure class="pipeline__strip" aria-label="discover, research, design, plan, implement, validate">
			<svg viewBox="0 0 720 80" class="pipeline__stripSvg" preserveAspectRatio="xMidYMid meet">
				<g fill="none" stroke="var(--sage-deep)" stroke-linecap="round">
					<path d="M68,28 L652,28" stroke-width="1" opacity="0.7" />
					<path d="M76,32 L644,32" stroke-width="0.5" opacity="0.25" />
				</g>
				{pipeline.map((skill, i) => {
					const x = 68 + i * (584 / (pipeline.length - 1));
					const isOptional = skill.data.name === "discover";
					return (
						<g>
							<circle cx={x} cy={28} r="13" fill="none" stroke="var(--sage)" stroke-width="0.7" opacity="0.4"
								stroke-dasharray={isOptional ? "2 2" : undefined} />
							<circle cx={x} cy={28} r="9" fill="var(--ink)" stroke="var(--sage)" stroke-width="1.1"
								stroke-dasharray={isOptional ? "3 2" : undefined} />
							<circle cx={x} cy={28} r="9" fill="var(--sage)" opacity="0.16" />
							<text x={x} y={31.2} text-anchor="middle"
								font-family="var(--font-mono)" font-size="9" fill="var(--washi)">{String(i + 1).padStart(2, "0")}</text>
							<text x={x} y={62} text-anchor="middle"
								font-family="var(--font-mono)" font-size="11"
								fill="var(--text-quiet)" letter-spacing="0.04em">{skill.data.name}</text>
						</g>
					);
				})}
			</svg>
		</figure>

		<div class="emaki-progress" aria-hidden="true">
			<span class="emaki-progress__fill" data-emaki-progress-fill></span>
		</div>
		<ol class="emaki" data-emaki aria-label="six-step pipeline, panels left to right">
			{pipeline.map((skill, i) => {
				const next = pipeline[i + 1];
				// pipeline is built from the PIPELINE tuple, so name is always a PipelineStep
				// and PIPELINE_META is total over PipelineStep — no undefined branch.
				const meta = PIPELINE_META[skill.data.name as PipelineStep];
				const artifact = ARTIFACT_WRITE_SITES[skill.data.name as PipelineStep];
				const isOptional = skill.data.name === "discover";
				const stepNum = String(i + 1).padStart(2, "0");
				return (
					<li class:list={["emaki__panel", isOptional && "emaki__panel--optional"]}
						data-emaki-panel data-step={i + 1}
						style={`--reveal-delay: ${i * 60}ms`}>
						<div class="emaki__head">
							<span class="emaki__num mono">{stepNum}</span>
							<span class="emaki__rule" aria-hidden="true"></span>
							<span class="emaki__name mono">/skill:{skill.data.name}</span>
							<span class="emaki__open mono" aria-hidden="true">open</span>
						</div>

						<div class="emaki__chips">
							{isOptional && <span class="chip chip--muted">optional</span>}
							{skill.data["disable-model-invocation"] && <span class="chip chip--ochre">manual only</span>}
						</div>

						<p class="emaki__tagline">{skill.tagline}</p>

						<div class="emaki__field" role="group" aria-label="information collected">
							<p class="emaki__fieldHead">
								<span class="emaki__tick mono" aria-hidden="true">i.</span>
								<span class="mono">collects</span>
							</p>
							<p class="emaki__collectList mono">
								{meta.collects.map((c, idx) => (
									<>
										<span class="emaki__collectItem">{c}</span>
										{idx < meta.collects.length - 1 && <span class="emaki__sep" aria-hidden="true"> · </span>}
									</>
								))}
							</p>
						</div>

						<div class="emaki__field" role="group" aria-label="rationale">
							<p class="emaki__fieldHead">
								<span class="emaki__tick mono" aria-hidden="true">ii.</span>
								<span class="mono">why</span>
							</p>
							<p class="emaki__rationale">{meta.why}</p>
						</div>

						<div class="emaki__produces" role="group" aria-label="artifact produced">
							<p class="emaki__fieldHead">
								<span class="emaki__tick mono" aria-hidden="true">iii.</span>
								<span class="mono">produces</span>
							</p>
							{artifact ? (
								<p class="mono emaki__artifactPath"><span aria-hidden="true">→ </span>{artifact}</p>
							) : (
								<p class="mono emaki__artifactPath emaki__artifactPath--empty">
									<span aria-hidden="true">→ </span>working-tree changes (no `.rpiv/artifacts/` artifact)
								</p>
							)}
							{next && (
								<p class="mono emaki__feeds">
									<span class="emaki__bullet" aria-hidden="true">∴</span>
									feeds <code>/skill:{next.data.name}</code>
								</p>
							)}
						</div>

						{skill.data.name === "plan" && (
							<aside class="emaki__hinge" aria-label="auxiliary skill">
								<span class="emaki__hingeRule" aria-hidden="true"></span>
								<div class="emaki__hingeBody">
									<div class="emaki__hingeHead">
										<span class="emaki__hingeKicker mono">aux</span>
										<span class="chip chip--ochre">/skill:{revise.data.name}</span>
									</div>
									<p class="emaki__hingeDesc">{revise.tagline}</p>
								</div>
							</aside>
						)}
					</li>
				);
			})}
		</ol>
		<p class="emaki__hint mono" aria-hidden="true">drag · scroll · ← → to advance</p>
	</div>
</section>

<script>
	(() => {
		const track = document.querySelector<HTMLElement>("[data-emaki]");
		if (!track) return;
		const panels = Array.from(track.querySelectorAll<HTMLElement>("[data-emaki-panel]"));
		const fill = document.querySelector<HTMLElement>("[data-emaki-progress-fill]");

		const reveal = new IntersectionObserver(
			(entries) => {
				for (const e of entries) {
					if (e.isIntersecting) {
						e.target.classList.add("is-revealed");
						reveal.unobserve(e.target);
					}
				}
			},
			{ threshold: 0, rootMargin: "0px 0px -12% 0px" },
		);
		for (const p of panels) reveal.observe(p);

		// Safety net: IO's first callback can race with deep-link / fast scroll.
		requestAnimationFrame(() => {
			const vh = window.innerHeight;
			for (const p of panels) {
				const r = p.getBoundingClientRect();
				if (r.top < vh && r.bottom > 0) {
					p.classList.add("is-revealed");
					reveal.unobserve(p);
				}
			}
		});

		let frame = 0;
		const updateActive = () => {
			const trackRect = track.getBoundingClientRect();
			const centre = trackRect.left + trackRect.width / 2;
			let bestIdx = 0;
			let bestDist = Infinity;
			panels.forEach((p, i) => {
				const r = p.getBoundingClientRect();
				const d = Math.abs(r.left + r.width / 2 - centre);
				if (d < bestDist) {
					bestDist = d;
					bestIdx = i;
				}
			});
			panels.forEach((p, i) => p.classList.toggle("is-open", i === bestIdx));

			if (fill) {
				const max = track.scrollWidth - track.clientWidth;
				const ratio = max > 0 ? track.scrollLeft / max : 0;
				fill.style.transform = `scaleX(${ratio})`;
			}
		};
		const schedule = () => {
			if (frame) return;
			frame = requestAnimationFrame(() => {
				frame = 0;
				updateActive();
			});
		};
		track.addEventListener("scroll", schedule, { passive: true });
		window.addEventListener("resize", schedule);
		updateActive();

		// Mouse drag-to-scroll. Native overflow-x covers touch + trackpad; this
		// adds parity for mouse users. Threshold separates click from drag so
		// in-panel links (e.g. /skill:revise chip) still receive their click.
		let dragging = false;
		let dragStartX = 0;
		let dragStartScroll = 0;
		let dragMoved = 0;
		const DRAG_THRESHOLD = 5;

		track.addEventListener("mousedown", (e) => {
			const me = e as MouseEvent;
			if (me.button !== 0) return;
			dragging = true;
			dragStartX = me.pageX;
			dragStartScroll = track.scrollLeft;
			dragMoved = 0;
			track.classList.add("is-dragging");
		});
		window.addEventListener("mousemove", (e) => {
			if (!dragging) return;
			const me = e as MouseEvent;
			const dx = me.pageX - dragStartX;
			dragMoved = Math.max(dragMoved, Math.abs(dx));
			track.scrollLeft = dragStartScroll - dx;
		});
		const endDrag = () => {
			if (!dragging) return;
			dragging = false;
			track.classList.remove("is-dragging");
		};
		window.addEventListener("mouseup", endDrag);
		window.addEventListener("blur", endDrag);
		// Suppress click that would fire on mouseup after a real drag.
		track.addEventListener(
			"click",
			(e) => {
				if (dragMoved > DRAG_THRESHOLD) {
					e.preventDefault();
					e.stopPropagation();
				}
			},
			true,
		);

		track.tabIndex = 0;
		track.addEventListener("keydown", (e) => {
			const ke = e as KeyboardEvent;
			if (ke.key !== "ArrowLeft" && ke.key !== "ArrowRight" && ke.key !== "Home" && ke.key !== "End") return;
			e.preventDefault();
			const current = panels.findIndex((p) => p.classList.contains("is-open"));
			let target = current;
			if (ke.key === "ArrowLeft") target = Math.max(0, current - 1);
			else if (ke.key === "ArrowRight") target = Math.min(panels.length - 1, current + 1);
			else if (ke.key === "Home") target = 0;
			else if (ke.key === "End") target = panels.length - 1;
			panels[target]?.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
		});
	})();
</script>

<style>
	#pipeline h2 { margin-bottom: var(--space-5); max-width: 32ch; }
	.pipeline__lede {
		color: var(--text-quiet);
		margin-bottom: var(--space-6);
		max-width: 64ch;
	}

	.pipeline__strip {
		margin: 0 0 var(--space-7);
		padding: var(--space-5) 0;
		border-top: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule);
		overflow-x: auto;
	}
	.pipeline__stripSvg {
		width: 100%;
		min-width: 560px;
		height: auto;
		display: block;
	}

	.emaki-progress {
		position: relative;
		height: 1px;
		background: var(--rule);
		margin: 0;
		overflow: hidden;
	}
	.emaki-progress__fill {
		display: block;
		height: 100%;
		width: 100%;
		background: linear-gradient(
			to right,
			var(--sage-deep) 0%,
			var(--sage) 60%,
			var(--ochre) 100%
		);
		transform: scaleX(0);
		transform-origin: left center;
		transition: transform var(--dur-fast) var(--ease-ink);
	}

	.emaki {
		--emaki-gap: var(--space-5);
		list-style: none;
		padding: var(--space-3) var(--space-1) var(--space-5);
		margin: 0;
		display: flex;
		align-items: stretch;
		gap: var(--emaki-gap);
		overflow-x: auto;
		overflow-y: hidden;
		scroll-snap-type: x mandatory;
		scroll-padding-inline: var(--space-3);
		-webkit-overflow-scrolling: touch;
		scrollbar-width: thin;
		scrollbar-color: var(--rule-strong) transparent;
		outline: none;
		cursor: grab;
	}
	.emaki.is-dragging {
		cursor: grabbing;
		scroll-snap-type: none;
		user-select: none;
	}
	.emaki:focus-visible {
		outline: 1px solid var(--sage);
		outline-offset: 4px;
	}
	.emaki::-webkit-scrollbar { height: 6px; }
	.emaki::-webkit-scrollbar-track { background: transparent; }
	.emaki::-webkit-scrollbar-thumb {
		background: var(--rule-strong);
		border-radius: var(--radius-md);
	}

	.emaki__panel {
		flex: 0 0 clamp(300px, 34vw, 420px);
		scroll-snap-align: start;
		position: relative;
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding: var(--space-4);
		background: var(--ink-raised);
		border-top: 1px solid var(--sage-deep);
		border-left: 1px solid var(--rule);
		border-right: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule-strong);
		overflow: hidden;

		opacity: 0;
		transform: translateY(8px);
		clip-path: inset(0 100% 0 0);
		transition:
			opacity var(--dur-ink) var(--ease-ink) var(--reveal-delay, 0ms),
			transform var(--dur-ink) var(--ease-ink) var(--reveal-delay, 0ms),
			clip-path var(--dur-ink) var(--ease-ink) var(--reveal-delay, 0ms),
			border-top-color var(--dur-quick) var(--ease-ink);
	}
	.emaki__panel.is-revealed {
		opacity: 1;
		transform: translateY(0);
		clip-path: inset(0 0 0 0);
	}
	/* No-JS fallback */
	@media (scripting: none) {
		.emaki__panel { opacity: 1; transform: none; clip-path: none; }
	}

	.emaki__panel::before {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			radial-gradient(800px 200px at 30% 0%, color-mix(in oklab, var(--ochre) 5%, transparent), transparent 60%),
			radial-gradient(600px 200px at 80% 100%, color-mix(in oklab, var(--sage) 4%, transparent), transparent 60%);
		mix-blend-mode: lighten;
	}

	.emaki__panel + .emaki__panel::after {
		content: "∴";
		position: absolute;
		top: 50%;
		left: calc(var(--emaki-gap) * -1);
		width: var(--emaki-gap);
		text-align: center;
		transform: translateY(-50%);
		font-family: var(--font-mono);
		font-size: var(--type-tiny);
		color: var(--text-distant);
		pointer-events: none;
	}

	.emaki__panel--optional {
		border-top-color: var(--ochre);
		border-top-style: dashed;
	}

	.emaki__panel.is-open {
		border-top-color: var(--ochre);
	}
	.emaki__panel.is-open .emaki__open { opacity: 1; }
	.emaki__panel.is-open .emaki__num { color: var(--ochre); }

	.emaki__head {
		display: grid;
		grid-template-columns: auto 1fr auto auto;
		align-items: center;
		gap: var(--space-2);
		padding-bottom: var(--space-2);
		border-bottom: 1px solid var(--rule-strong);
	}
	.emaki__num {
		font-size: var(--type-tiny);
		letter-spacing: 0.18em;
		color: var(--washi);
		transition: color var(--dur-quick) var(--ease-ink);
	}
	.emaki__rule {
		display: block;
		height: 1px;
		background: var(--rule-strong);
	}
	.emaki__name {
		font-size: var(--type-small);
		color: var(--sage);
		letter-spacing: 0;
	}
	.emaki__open {
		font-size: var(--type-tiny);
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ochre);
		opacity: 0;
		transition: opacity var(--dur-quick) var(--ease-ink);
	}

	.emaki__chips {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		min-height: 0;
	}
	.emaki__chips:empty { display: none; }

	.emaki__tagline {
		font-family: var(--font-serif);
		font-size: var(--type-small);
		line-height: var(--leading-snug);
		color: var(--text);
		margin: 0;
	}

	.emaki__field {
		padding-top: var(--space-2);
		border-top: 1px solid var(--rule);
	}
	.emaki__fieldHead {
		display: flex;
		align-items: baseline;
		gap: var(--space-2);
		font-size: var(--type-tiny);
		font-weight: 400;
		letter-spacing: 0.04em;
		color: var(--text-distant);
		margin: 0 0 var(--space-1);
		text-transform: uppercase;
	}
	.emaki__tick {
		display: inline-block;
		min-width: 1.5em;
		font-size: var(--type-tiny);
		color: var(--sage);
		letter-spacing: 0;
		text-transform: none;
	}

	.emaki__collectList {
		font-size: var(--type-tiny);
		line-height: var(--leading-snug);
		color: var(--text-quiet);
		margin: 0;
	}
	.emaki__collectItem {
		color: var(--washi-soft);
	}
	.emaki__sep {
		color: var(--text-distant);
		margin: 0 2px;
	}

	.emaki__rationale {
		font-family: var(--font-serif);
		font-size: var(--type-small);
		line-height: var(--leading-snug);
		color: var(--text-quiet);
		margin: 0;
		max-width: 40ch;
	}

	.emaki__produces {
		/* margin-top:auto pins produces to the panel's ground line under stretch */
		margin-top: auto;
		padding-top: var(--space-3);
		border-top: 1px solid var(--rule-strong);
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.emaki__artifactPath {
		font-size: var(--type-tiny);
		color: var(--ochre);
		margin: 0;
		word-break: break-all;
	}
	.emaki__artifactPath--empty {
		color: var(--text-distant);
		font-style: italic;
	}
	.emaki__feeds {
		font-size: var(--type-tiny);
		color: var(--text-distant);
		margin: 0;
		display: flex;
		gap: var(--space-2);
		align-items: baseline;
	}
	.emaki__feeds code {
		color: var(--sage);
		background: transparent;
	}
	.emaki__bullet {
		color: var(--text-distant);
	}

	.emaki__hinge {
		margin-top: var(--space-2);
		padding: var(--space-2) var(--space-3);
		display: grid;
		grid-template-columns: 2px 1fr;
		gap: var(--space-2);
		background: color-mix(in oklab, var(--ochre) 6%, transparent);
		border-radius: var(--radius-sm);
	}
	.emaki__hingeRule {
		display: block;
		background: var(--ochre);
		opacity: 0.55;
		border-radius: var(--radius-xs);
	}
	.emaki__hingeBody {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.emaki__hingeHead {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		align-items: baseline;
	}
	.emaki__hingeKicker {
		font-size: var(--type-tiny);
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ochre);
	}
	.emaki__hingeDesc {
		font-family: var(--font-serif);
		color: var(--text-quiet);
		font-size: var(--type-tiny);
		line-height: var(--leading-snug);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.emaki__hint {
		text-align: right;
		max-width: none;
		margin: var(--space-3) 0 0;
		font-size: var(--type-tiny);
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--text-distant);
	}

	@media (max-width: 720px) {
		.emaki__panel {
			flex-basis: 82vw;
			padding: var(--space-4);
		}
	}

	@media (max-width: 480px) {
		.emaki {
			flex-direction: column;
			overflow-x: visible;
			scroll-snap-type: none;
			gap: var(--space-4);
		}
		.emaki__panel {
			flex-basis: auto;
			width: 100%;
		}
		.emaki__panel + .emaki__panel::after {
			content: "∴";
			top: calc(var(--space-4) * -1);
			left: 50%;
			transform: translateX(-50%);
			width: auto;
		}
		.emaki__hint { display: none; }
	}

	@media (prefers-reduced-motion: reduce) {
		.emaki__panel {
			opacity: 1;
			transform: none;
			clip-path: none;
			transition: none;
		}
		.emaki__num,
		.emaki__open,
		.emaki-progress__fill { transition: none; }
	}
</style>
