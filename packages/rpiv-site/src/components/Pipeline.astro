---
import { ARTIFACT_WRITE_SITES, PIPELINE_META, type PipelineStep, getPipelineSkills, getSkill } from "../lib/skills";
const pipeline = await getPipelineSkills();
const revise = await getSkill("revise");
---

<section id="pipeline">
	<div class="container">
		<h2>A six-step chain. One artifact between each.</h2>
		<p class="pipeline__lede">
			Each node is a skill. The artifact one writes is the next one&rsquo;s input.
		</p>

		<ol class="pipeline__list">
			{pipeline.map((skill, i) => {
				const next = pipeline[i + 1];
				const meta = PIPELINE_META[skill.data.name as PipelineStep];
				const artifact = ARTIFACT_WRITE_SITES[skill.data.name as PipelineStep];
				const isOptional = skill.data.name === "discover";
				const stepNum = String(i + 1).padStart(2, "0");
				
				return (
					<li class="pipeline__item" id={`skill-${skill.data.name}`}>
						<h3>
							<span class="mono step-num">{stepNum}.</span> 
							/skill:{skill.data.name}
							{isOptional && <span class="badge">[optional]</span>}
							{skill.data["disable-model-invocation"] && <span class="badge">[manual only]</span>}
						</h3>

						<p><strong>{skill.tagline}</strong></p>

						<div class="pipeline__details">
							<div>
								<strong>Collects:</strong>
								<ul>
									{meta.collects.map((c) => (
										<li>{c}</li>
									))}
								</ul>
							</div>

							<div>
								<strong>Why:</strong>
								<p>{meta.why}</p>
							</div>

							<div>
								<strong>Produces:</strong>
								{artifact ? (
									<p><code>{artifact}</code></p>
								) : (
									<p>working-tree changes</p>
								)}
								{next && (
									<p><em>Feeds into: <code>/skill:{next.data.name}</code></em></p>
								)}
							</div>
						</div>

						{skill.data.name === "plan" && (
							<div class="pipeline__aux">
								<strong>Auxiliary skill:</strong> <code>/skill:{revise.data.name}</code>
								<p>{revise.tagline}</p>
							</div>
						)}
					</li>
				);
			})}
		</ol>
	</div>
</section>

<style>
	.pipeline__list {
		list-style: none;
		padding: 0;
		margin: var(--space-6) 0;
	}

	.pipeline__item {
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-6);
		border-bottom: 1px solid var(--rule);
	}

	.pipeline__item h3 {
		margin-bottom: var(--space-2);
		color: var(--sage);
	}

	.step-num {
		color: var(--text-distant);
	}

	.badge {
		font-size: var(--type-tiny);
		color: var(--ochre);
		margin-left: var(--space-2);
		vertical-align: middle;
	}

	.pipeline__details {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		margin-top: var(--space-4);
		background: var(--ink-raised);
		padding: var(--space-4);
		border-left: 4px solid var(--rule-strong);
	}

	.pipeline__details ul {
		margin-top: var(--space-2);
		padding-left: var(--space-4);
	}

	.pipeline__aux {
		margin-top: var(--space-4);
		padding: var(--space-4);
		background: var(--ink-muted);
		border: 1px dashed var(--rule-strong);
	}
</style>
