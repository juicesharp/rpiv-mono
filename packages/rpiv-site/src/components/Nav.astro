<header class="nav" data-nav>
	<div class="container nav__inner">
		<div class="nav__head">
			<a href="#top" class="nav__brand mono">rpiv-pi</a>
			<span class="nav__counter mono" aria-hidden="true">
				<span class="nav__counter-rule"></span>
				<span class="nav__counter-num" data-nav-counter>—</span>
				<span class="nav__counter-sep">/</span>
				<span class="nav__counter-total">06</span>
			</span>
		</div>
		<nav class="nav__links mono" aria-label="primary">
			<a href="#pipeline" data-nav-link="pipeline">pipeline</a>
			<a href="#flows"    data-nav-link="flows">blueprint</a>
			<a href="#review"   data-nav-link="review">review</a>
			<a href="#agents"   data-nav-link="agents">agents</a>
			<a href="#siblings" data-nav-link="siblings">siblings</a>
			<a href="#install"  data-nav-link="install">install</a>
		</nav>
	</div>
</header>

<style>
	.nav {
		position: sticky;
		top: 0;
		z-index: 10;
		background: color-mix(in oklab, var(--ink) 88%, transparent);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--rule);
	}
	.nav__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-5);
		padding-top: var(--space-3);
		padding-bottom: var(--space-3);
	}
	.nav__head {
		display: contents;
	}
	.nav__brand {
		font-size: var(--type-small);
		color: var(--washi);
		letter-spacing: 0.04em;
		border-bottom: none;
	}
	.nav__brand:hover { color: var(--sage); }

	/* Section counter — mobile-only flourish that echoes
	   ScrollIndicator's `.indicator__foot` (tabular numerals + 0.14em
	   tracking + faint hairline). Restores the orientation cue the side
	   rail provides on desktop, where the rail is hidden below 960px. */
	.nav__counter {
		display: none;
		align-items: baseline;
		gap: 2px;
		font-size: var(--type-tiny);
		letter-spacing: 0.14em;
		color: var(--text-distant);
		font-variant-numeric: tabular-nums;
	}
	.nav__counter-rule {
		display: block;
		width: var(--space-6);
		height: 1px;
		margin-right: var(--space-3);
		align-self: center;
		background: linear-gradient(
			90deg,
			transparent,
			var(--rule-strong) 60%,
			var(--rule-strong)
		);
	}
	.nav__counter-num {
		color: var(--washi-soft);
		min-width: 1.3em;
		text-align: right;
	}
	.nav__counter-sep { opacity: 0.5; }
	.nav__counter-total { opacity: 0.7; }

	.nav__links {
		display: flex;
		gap: var(--space-4);
		font-size: var(--type-tiny);
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}
	.nav__links a {
		position: relative;
		color: var(--text-distant);
		border-bottom: none;
		transition: color var(--dur-ink) var(--ease-ink);
	}
	.nav__links a:hover { color: var(--washi); }

	/* Active-section state — agrees with the side ScrollIndicator's hanko seal.
	   Active link gets washi text + a 1px ochre underline tick that grows from
	   left, matching the indicator's `.indicator__line` widening behavior. */
	.nav__links a.is-active {
		color: var(--washi);
	}
	.nav__links a.is-active::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -4px;
		height: 1px;
		background: var(--ochre);
		transform-origin: left center;
		animation: nav-tick-in 360ms var(--ease-ink) forwards;
	}
	@keyframes nav-tick-in {
		from { transform: scaleX(0); }
		to   { transform: scaleX(1); }
	}
	@media (prefers-reduced-motion: reduce) {
		.nav__links a.is-active::after { animation: none; }
	}

	/* Mobile (≤720px) — the side ScrollIndicator is hidden below 960px,
	   so the top nav has to carry both wayfinding and section-progress.
	   Stack into two rows: brand + tabular counter on top, a full-width
	   6-column grid of links below. The grid distributes evenly across
	   any viewport, eliminating the overflow that the previous
	   shrink-the-gap approach hit on narrow phones. */
	@media (max-width: 720px) {
		.nav__inner {
			flex-direction: column;
			align-items: stretch;
			gap: var(--space-3);
			padding-top: var(--space-3);
			padding-bottom: 0;
		}
		.nav__head {
			display: flex;
			justify-content: space-between;
			align-items: baseline;
		}
		.nav__counter { display: inline-flex; }

		.nav__links {
			display: grid;
			grid-template-columns: repeat(6, 1fr);
			gap: 0;
			font-size: 10px;
			letter-spacing: 0.12em;
			border-top: 1px solid var(--rule);
			padding-top: var(--space-3);
		}
		.nav__links a {
			text-align: center;
			padding: 2px 4px var(--space-3);
		}
		.nav__links a.is-active::after {
			left: 18%;
			right: 18%;
			bottom: 4px;
		}
	}

	/* Sub-480px — six tracked-out words can't share a single row gracefully
	   below ~440px. Reflow to a 3-column / 2-row plate, still equal-width,
	   still anchored to the same active-tick rhythm. */
	@media (max-width: 480px) {
		.nav__links {
			grid-template-columns: repeat(3, 1fr);
			row-gap: var(--space-3);
			padding-bottom: var(--space-3);
		}
		.nav__links a { padding-bottom: 2px; }
		.nav__links a.is-active::after {
			left: 22%;
			right: 22%;
			bottom: -3px;
		}
	}
</style>

<script>
	(() => {
		const nav = document.querySelector<HTMLElement>("[data-nav]");
		if (!nav) return;
		const links = Array.from(
			nav.querySelectorAll<HTMLAnchorElement>("[data-nav-link]"),
		);
		const counter = nav.querySelector<HTMLElement>("[data-nav-counter]");
		const targets = links
			.map((link) => {
				const id = link.dataset.navLink;
				if (!id) return null;
				const el = document.getElementById(id);
				return el ? { link, el } : null;
			})
			.filter((x): x is { link: HTMLAnchorElement; el: HTMLElement } => !!x);
		if (!targets.length) return;

		let rafId = 0;
		const setActive = () => {
			rafId = 0;
			const anchorY = window.innerHeight * 0.34;
			let activeIndex = -1;
			for (let i = 0; i < targets.length; i++) {
				const top = targets[i].el.getBoundingClientRect().top;
				if (top - anchorY <= 0) activeIndex = i;
			}
			targets.forEach((t, i) => {
				t.link.classList.toggle("is-active", i === activeIndex);
				if (i === activeIndex) t.link.setAttribute("aria-current", "true");
				else t.link.removeAttribute("aria-current");
			});
			if (counter) {
				counter.textContent =
					activeIndex < 0 ? "—" : String(activeIndex + 1).padStart(2, "0");
			}
		};

		const onScroll = () => {
			if (rafId) return;
			rafId = requestAnimationFrame(setActive);
		};
		window.addEventListener("scroll", onScroll, { passive: true });
		window.addEventListener("resize", onScroll, { passive: true });
		setActive();
	})();
</script>
