---
import { VERSION } from "../lib/version";
---

<header class="nav">
	<div class="container nav__inner">
		<div class="nav__brand-group">
			<a href="/" class="nav__brand mono">rpiv-pi</a>
			<a
				class="nav__version mono"
				href={`https://www.npmjs.com/package/@juicesharp/rpiv-pi/v/${VERSION}`}
				target="_blank"
				rel="noopener"
			>v{VERSION}</a>
		</div>

		<nav class="nav__links mono" aria-label="primary">
			<a href="/">home</a>
			<a href="/pipeline">pipeline</a>
			<a href="/agents">agents</a>
			<a href="/docs">docs</a>
			<a href="https://github.com/juicesharp/rpiv-mono">github</a>
		</nav>
	</div>
</header>

<style>
	.nav {
		padding: var(--space-4) 0;
		border-bottom: 1px solid var(--rule);
		background: var(--ink);
	}

	.nav__inner {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		justify-content: space-between;
		align-items: center;
	}

	.nav__brand-group {
		display: flex;
		align-items: baseline;
		gap: var(--space-3);
	}

	.nav__brand {
		font-size: var(--type-base);
		color: var(--washi);
		font-weight: bold;
		text-decoration: none;
	}

	.nav__version {
		font-size: var(--type-small);
		color: var(--text-distant);
		text-decoration: none;
	}

	.nav__links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		font-size: var(--type-small);
	}

	.nav__links a {
		color: var(--sage);
		text-decoration: none;
	}

	.nav__links a:hover {
		color: var(--washi);
		text-decoration: underline;
	}
</style>
