---
import { VERSION } from "../lib/version";

const currentPath = Astro.url.pathname;

function isActive(path: string) {
	if (path === "/") {
		return currentPath === "/";
	}
	// For paths like /pipeline or /docs, check if current path starts with it
	return currentPath.startsWith(path);
}
---

<header class="nav">
	<div class="container nav__inner">
		<div class="nav__brand-group">
			<a href="/" class="nav__brand mono">rpiv-pi</a>
			<a
				class="nav__version mono"
				href={`https://www.npmjs.com/package/@juicesharp/rpiv-pi/v/${VERSION}`}
				target="_blank"
				rel="noopener"
			>v{VERSION}</a>
		</div>

		<nav class="nav__links mono" aria-label="primary">
			<a href="/" class={isActive("/") ? "is-active" : ""}>home</a>
			<a href="/pipeline" class={isActive("/pipeline") ? "is-active" : ""}>pipeline</a>
			<a href="/agents" class={isActive("/agents") ? "is-active" : ""}>agents</a>
			<a href="/tools" class={isActive("/tools") ? "is-active" : ""}>tools</a>
			<a href="/docs" class={isActive("/docs") ? "is-active" : ""}>docs</a>
			<a href="https://github.com/juicesharp/rpiv-mono">github</a>
		</nav>
	</div>
</header>

<style>
	.nav {
		padding: var(--space-4) 0;
		border-bottom: 1px solid var(--rule);
		background: var(--ink);
	}

	.nav__inner {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		justify-content: space-between;
		align-items: center;
	}

	.nav__brand-group {
		display: flex;
		align-items: baseline;
		gap: var(--space-3);
	}

	.nav__brand {
		font-size: var(--type-base);
		color: var(--washi);
		font-weight: bold;
		text-decoration: none;
	}

	.nav__version {
		font-size: var(--type-small);
		color: var(--text-distant);
		text-decoration: none;
	}

	.nav__links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		font-size: var(--type-small);
	}

	.nav__links a {
		color: var(--sage);
		text-decoration: none;
	}

	.nav__links a:hover {
		color: var(--washi);
		text-decoration: underline;
	}

	.nav__links a.is-active {
		color: var(--washi);
		font-weight: bold;
		text-decoration: underline;
		text-decoration-color: var(--ochre);
		text-decoration-thickness: 2px;
		text-underline-offset: 4px;
	}
</style>
