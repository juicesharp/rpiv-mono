---
import "../styles/global.css";
import Colophon from "../components/Colophon.astro";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "rpiv-pi",
	description = "A pipeline of skills, subagents, and extensions for the Pi coding agent.",
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/og-v2.jpg", Astro.site).toString();

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebSite",
			"@id": "https://rpiv-pi.com/#website",
			url: "https://rpiv-pi.com/",
			name: "rpiv-pi",
			description,
			inLanguage: "en",
		},
		{
			"@type": "SoftwareApplication",
			name: "rpiv-pi",
			applicationCategory: "DeveloperApplication",
			operatingSystem: "macOS, Linux, Windows",
			description,
			url: "https://rpiv-pi.com/",
			offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
			license: "https://opensource.org/licenses/MIT",
		},
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="dark" />
		<meta name="google-site-verification" content="Ko8ywIGky_WAEHlP06NUR5WJ4UCqTfT8N40zfZi5OOU" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

		{/* Webfont — JetBrains Mono via Fontsource CDN. Ensures the site's mono
		    voice renders consistently for visitors without Berkeley Mono / SF Mono
		    installed. Single weight (regular 400) keeps the budget tight (~30KB).
		    Cascade fallback in tokens.css still applies if the CDN is blocked. */}
		<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://cdn.jsdelivr.net/npm/@fontsource/jetbrains-mono/400.css"
		/>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/@fontsource/jetbrains-mono/400.css"
		/>

		<meta property="og:site_name" content="rpiv-pi" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:type" content="image/jpeg" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="rpiv-pi · research → design → ship" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@juicesharp" />
		<meta name="twitter:creator" content="@juicesharp" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content="rpiv-pi · research → design → ship" />

		<link rel="sitemap" href="/sitemap-index.xml" />

		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body>
		<slot />

		<Colophon />

		<footer>
			<div class="container">
				<p class="mono">
					<a href="https://www.npmjs.com/package/@juicesharp/rpiv-pi">npm</a>
					&nbsp;·&nbsp;
					<a href="https://github.com/juicesharp/rpiv-mono">github</a>
					&nbsp;·&nbsp;
					<span>MIT &copy; <a href="https://x.com/juicesharp" target="_blank" rel="noopener">juicesharp</a></span>
				</p>
			</div>
		</footer>
	</body>
</html>
