#!/bin/sh

# Capture staged files before biome potentially rewrites them
STAGED_FILES=$(git diff --cached --name-only)

# Decision-code contamination guard — fail-fast before the slower biome + tsc pass.
echo "Checking for decision-code contamination..."
npm run check:decision-codes
if [ $? -ne 0 ]; then
  echo "❌ Decision-code citations found — reword the comment to state the contract (see scripts/check-no-decision-codes.mjs)."
  exit 1
fi

echo "Running formatting, linting, and type checking..."
npm run check
if [ $? -ne 0 ]; then
  echo "❌ Checks failed. Please fix the errors before committing."
  exit 1
fi

# Restage any files biome --write modified (skip paths now covered by .gitignore)
for file in $STAGED_FILES; do
  if [ -f "$file" ] && ! git check-ignore -q "$file"; then
    git add "$file"
  fi
done

echo "✅ All pre-commit checks passed!"
