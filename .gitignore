# No trailing slash: also matches a stray node_modules SYMLINK (a dir-only
# `node_modules/` pattern let one slip into the #76 squash via `git add -A`).
node_modules
packages/*/node_modules

*.log
.DS_Store
*.tsbuildinfo
*.cpuprofile

.pi/

# Local-only (not version-controlled)
.rpiv/guidance/
**/.rpiv/guidance/
.rpiv/artifacts/
**/.rpiv/artifacts/
.rpiv/workflows/
**/.rpiv/workflows/
thoughts/

# Environment
.env

# Editor files
.vscode/
.zed/
.idea/
*.swp
*.swo
*~

# Agent metadata (Claude Code local session state)
.claude/

# Package specific
.npm/
coverage/
.nyc_output/
packages/rpiv-site/dist/
packages/*/.astro/
# Astro generates a `.astro/` cache wherever it's invoked from. The
# packages-level rule above doesn't cover the case of running Astro from the
# monorepo root (e.g. via a workspace script), so ignore the root cache too.
/.astro/
